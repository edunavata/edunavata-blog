---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { getPostUrl, getReadingTime } from '@/i18n/utils';
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const tagsByLang = new Map<string, Map<string, typeof posts>>();

  posts.forEach(post => {
    const lang = post.data.lang;
    if (!tagsByLang.has(lang)) tagsByLang.set(lang, new Map());
    const langTags = tagsByLang.get(lang)!;
    post.data.tags.forEach((tag: string) => {
      if (!langTags.has(tag)) langTags.set(tag, []);
      langTags.get(tag)!.push(post);
    });
  });

  const paths: any[] = [];
  tagsByLang.forEach((tags, lang) => {
    tags.forEach((posts, tag) => {
      paths.push({ params: { lang, tag }, props: { tag, posts } });
    });
  });
  return paths;
};

const { tag, posts: tagPosts } = Astro.props as { tag: string; posts: CollectionEntry<'posts'>[] };
const lang = Astro.params.lang as 'es' | 'en';
const sorted = tagPosts.sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={`#${tag}`} lang={lang}>
  <main style="max-width:720px; margin:0 auto; padding:64px 32px 96px;">
    <header style="margin-bottom:40px;">
      <div style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:14px;">/ tags / {tag}</div>
      <h1 style="font-family:'Source Serif 4',serif; font-weight:600; font-size:clamp(36px,4vw,44px); line-height:1.15; letter-spacing:-0.015em; color:var(--text); margin:0 0 12px;">#{tag}</h1>
      <p style="font-family:'Source Serif 4',serif; font-size:17px; line-height:1.6; color:var(--text-2); margin:0;">
        {sorted.length} artículos etiquetados con <em style="color:var(--text);">#{tag}</em>
      </p>
    </header>

    <div style="display:flex; flex-direction:column;">
      {sorted.map((post: any) => (
        <PostCard
          title={post.data.title}
          href={getPostUrl(lang, post.data.slug)}
          date={post.data.date.toISOString()}
          tags={post.data.tags}
          description={post.data.description}
          readingTime={getReadingTime(post.body ?? '')}
          variant="row"
        />
      ))}
    </div>
  </main>
</BaseLayout>