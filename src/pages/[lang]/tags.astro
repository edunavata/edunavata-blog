---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '@/i18n/utils';
import { SITE } from '@/config/site';

export const getStaticPaths = () => [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];

const { lang } = Astro.params as { lang: 'es' | 'en' };
const t = useTranslations(lang);

const allPosts = await getCollection('posts', ({ data }) => data.lang === lang && !data.draft);

const allTags = new Map<string, number>();
allPosts.forEach((p) =>
  p.data.tags.forEach((tag) => {
    allTags.set(tag, (allTags.get(tag) || 0) + 1);
  })
);

const tagTerms = [...allTags.entries()].sort((a, b) => a[0].localeCompare(b[0]));
const freqTerms = [...allTags.entries()].sort((a, b) => b[1] - a[1]);
const maxCount = freqTerms[0]?.[1] || 1;

const categories = new Map<string, number>();
allPosts.forEach((p) =>
  p.data.categories.forEach((cat) => {
    categories.set(cat, (categories.get(cat) || 0) + 1);
  })
);

const alphaGroups: { letter: string; terms: [string, number][] }[] = [];
const groupMap = new Map<string, [string, number][]>();
tagTerms.forEach(([name, count]) => {
  const letter = name[0].toUpperCase();
  if (!groupMap.has(letter)) groupMap.set(letter, []);
  groupMap.get(letter)!.push([name, count]);
});
for (const [letter, terms] of [...groupMap.entries()].sort()) {
  alphaGroups.push({ letter, terms });
}

const tagsTitle = t('nav.tags');
const tagsDescription = t('tags.description');
const tagsUrl = new URL(`/${lang}/tags/`, SITE.url).toString();
const collectionPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: tagsTitle,
  description: tagsDescription,
  url: tagsUrl,
  inLanguage: SITE.hreflang[lang],
  isPartOf: { '@type': 'WebSite', name: SITE.title, url: SITE.url },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: tagTerms.length,
    itemListElement: tagTerms.map(([name, count], i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name,
      url: new URL(`/${lang}/tags/${name}/`, SITE.url).toString(),
      description: `${count} ${count === 1 ? 'post' : 'posts'}`,
    })),
  },
};
---

<BaseLayout title={tagsTitle} description={tagsDescription} lang={lang} noindex>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(collectionPageJsonLd)}
    slot="head"
  />
  <div style="max-width:1000px; margin:0 auto; padding:64px 32px 96px;">
    <header style="margin-bottom:40px;">
      <div
        style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:14px;"
      >
        / tags
      </div>
      <h1
        style="font-family:'Source Serif 4 Variable',serif; font-weight:600; font-size:clamp(36px,4vw,44px); line-height:1.15; letter-spacing:-0.015em; color:var(--text); margin:0 0 12px;"
      >
        Tags
      </h1>
      <p
        style="font-family:'Source Serif 4 Variable',serif; font-size:17px; line-height:1.6; color:var(--text-2); margin:0; max-width:60ch;"
      >
        {t('tags.description')}
        <a href={`/${lang}/blog/`} style="color:var(--accent); text-decoration:none;"
          >{lang === 'es' ? 'el listado completo' : 'the full listing'}</a
        >.
      </p>
      <div
        style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--text-3); margin-top:18px; display:flex; align-items:center; gap:10px; flex-wrap:wrap;"
      >
        <span><span id="terms-shown">{allTags.size}</span> tags</span>
        <span
          style="width:3px; height:3px; border-radius:50%; background:var(--text-3); opacity:0.6;"
        ></span>
        <span>{allPosts.length} {t('blog.articles')}</span>
      </div>
    </header>

    <div style="display:flex; gap:6px; margin-bottom:32px; border-bottom:1px solid var(--border);">
      <a class="tax-tab active" href={`/${lang}/tags/`}
        >Tags <span class="ct">{allTags.size}</span></a
      >
      <a class="tax-tab" href={`/${lang}/categories/`}
        >{t('nav.categories')} <span class="ct">{categories.size}</span></a
      >
    </div>

    <div style="display:flex; align-items:center; gap:12px; margin-bottom:32px; flex-wrap:wrap;">
      <label
        style="flex:1; min-width:240px; display:flex; align-items:center; gap:10px; height:40px; padding:0 14px; border:1px solid var(--border); border-radius:8px; background:transparent;"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          style="color:var(--text-3);"
          ><circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path></svg
        >
        <input
          id="search-input"
          type="text"
          placeholder={t('taxonomy.filterPlaceholder')}
          style="flex:1; background:transparent; border:none; color:var(--text); font-family:'Geist Variable',sans-serif; font-size:14px; outline:none;"
        />
        <kbd
          style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text-3); border:1px solid var(--border); padding:1px 6px; border-radius:4px; background:var(--surface);"
          >/</kbd
        >
      </label>
      <div
        style="display:flex; gap:4px; border:1px solid var(--border); border-radius:8px; padding:3px;"
      >
        <button class="sort-btn active" data-view="alpha">
          <svg
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="M3 6h13M3 12h9M3 18h6"></path></svg
          >
          {t('taxonomy.alpha')}
        </button>
        <button class="sort-btn" data-view="freq">
          <svg
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="M3 18h4M3 12h8M3 6h13"></path></svg
          >
          {t('taxonomy.frequency')}
        </button>
      </div>
    </div>

    <!-- Alphabetical view -->
    <div class="alpha-list" id="alpha-list">
      {
        alphaGroups.map((group) => (
          <div
            class="alpha-group"
            data-letter={group.letter}
            style="display:grid; grid-template-columns:100px 1fr; gap:32px; padding:28px 0; border-bottom:1px solid var(--border);"
          >
            <div style="font-family:'Source Serif 4 Variable',serif; font-size:32px; font-weight:600; line-height:1; color:var(--text-2); letter-spacing:-0.02em;">
              {group.letter}
              <div style="width:32px; height:1px; background:var(--border-strong); margin-top:12px;" />
            </div>
            <div
              class="alpha-terms"
              style="display:grid; grid-template-columns:repeat(2,1fr); gap:4px 24px;"
            >
              {group.terms.map(([name, count]) => (
                <a
                  class="term-row"
                  href={`/${lang}/tags/${name}/`}
                  data-name={name}
                  style="display:flex; align-items:baseline; gap:12px; padding:10px 0; text-decoration:none; color:inherit;"
                >
                  <span
                    class="term-name"
                    style="font-family:'Geist Variable',sans-serif; font-size:16px; font-weight:500; color:var(--text);"
                  >
                    {name}
                  </span>
                  <span
                    class="term-count"
                    style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); margin-left:auto;"
                  >
                    {count}
                  </span>
                  <span
                    class="term-arrow"
                    style="color:var(--accent); opacity:0; transform:translateX(-4px); transition:all 200ms ease;"
                  >
                    →
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Frequency view -->
    <div class="freq-list" id="freq-list" style="display:none; flex-direction:column;">
      {
        freqTerms.map(([name, count], i) => (
          <a
            class="freq-row"
            href={`/${lang}/tags/${name}/`}
            data-name={name}
            style="display:grid; grid-template-columns:32px minmax(140px,220px) 1fr 56px; align-items:center; gap:20px; padding:16px 0; border-bottom:1px solid var(--border); text-decoration:none; color:inherit;"
          >
            <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-align:right;">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span style="font-family:'Geist Variable',sans-serif; font-size:16px; font-weight:500; color:var(--text);">
              {name}
            </span>
            <span style="position:relative; height:6px; background:var(--bar-track); border-radius:3px; overflow:hidden;">
              <span
                class="fill"
                style={`height:100%; background:var(--bar); border-radius:3px; display:block; width:${((count / maxCount) * 100).toFixed(1)}%;`}
              />
            </span>
            <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--text-2); text-align:right;">
              {count}
            </span>
          </a>
        ))
      }
    </div>

    <div
      class="empty"
      id="empty"
      style="padding:80px 0; text-align:center; color:var(--text-3); font-family:'JetBrains Mono',monospace; font-size:13px; display:none;"
    >
      {t('taxonomy.noResults')}
    </div>
  </div>
</BaseLayout>

<style>
  .tax-tab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--text-2);
    padding: 10px 14px 12px;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    transition: all 150ms ease;
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }
  .tax-tab .ct {
    color: var(--text-3);
    font-size: 11px;
  }
  .tax-tab:hover {
    color: var(--text);
  }
  .tax-tab.active {
    color: var(--text);
    border-bottom-color: var(--accent);
  }
  .sort-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--text-2);
    padding: 7px 12px;
    border: none;
    background: transparent;
    border-radius: 5px;
    cursor: pointer;
    transition: all 150ms ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .sort-btn:hover {
    color: var(--text);
  }
  .sort-btn.active {
    background: var(--surface);
    color: var(--text);
  }
  .term-row:hover .term-name {
    color: var(--accent);
  }
  .term-row:hover .term-arrow {
    opacity: 1;
    transform: translateX(0);
  }
  .freq-row:hover .freq-name {
    color: var(--accent);
  }
  .empty.show {
    display: block !important;
  }
  @media (max-width: 720px) {
    .alpha-group {
      grid-template-columns: 1fr !important;
      gap: 14px !important;
    }
    .alpha-terms {
      grid-template-columns: 1fr !important;
    }
    .freq-row {
      grid-template-columns: 24px 1fr 48px !important;
    }
    .freq-row .freq-bar {
      display: none !important;
    }
  }
</style>

<script is:inline>
  (function () {
    document.querySelectorAll('.sort-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.sort-btn').forEach(function (b) {
          b.classList.remove('active');
        });
        btn.classList.add('active');
        document.getElementById('alpha-list').style.display =
          btn.dataset.view === 'freq' ? 'none' : '';
        var fl = document.getElementById('freq-list');
        if (btn.dataset.view === 'freq') {
          fl.style.display = 'flex';
          fl.style.flexDirection = 'column';
        } else {
          fl.style.display = 'none';
        }
        applyFilter();
      });
    });
    var search = document.getElementById('search-input');
    var empty = document.getElementById('empty');
    var termsShown = document.getElementById('terms-shown');
    function applyFilter() {
      var q = ((search && search.value) || '').trim().toLowerCase();
      var visible = 0;
      document.querySelectorAll('.term-row').forEach(function (r) {
        var show = !q || r.dataset.name.toLowerCase().includes(q);
        r.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      document.querySelectorAll('.alpha-group').forEach(function (g) {
        var hasVisible = [].slice.call(g.querySelectorAll('.term-row')).some(function (r) {
          return r.style.display !== 'none';
        });
        g.style.display = hasVisible ? '' : 'none';
      });
      document.querySelectorAll('.freq-row').forEach(function (r) {
        r.style.display = !q || r.dataset.name.toLowerCase().includes(q) ? '' : 'none';
      });
      if (empty) empty.classList.toggle('show', visible === 0);
      if (termsShown) termsShown.textContent = visible;
    }
    if (search) search.addEventListener('input', applyFilter);
    if (!window.__tagsKeydown) {
      window.__tagsKeydown = true;
      window.addEventListener('keydown', function (e) {
        var s = document.getElementById('search-input');
        if (e.key === '/' && document.activeElement !== s) {
          e.preventDefault();
          if (s) s.focus();
        }
      });
    }
  })();
</script>
