---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '@/i18n/utils';
import { SITE } from '@/config/site';

export const getStaticPaths = () => [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];

const { lang } = Astro.params as { lang: 'es' | 'en' };
const t = useTranslations(lang);

const allPosts = await getCollection('posts', ({ data }) => data.lang === lang && !data.draft);

const categories = new Map<string, number>();
allPosts.forEach((p) =>
  p.data.categories.forEach((cat) => {
    categories.set(cat, (categories.get(cat) || 0) + 1);
  })
);

const catTerms = [...categories.entries()].sort((a, b) => a[0].localeCompare(b[0]));
const maxCount = Math.max(...categories.values(), 1);

const categoriesUrl = new URL(`/${lang}/categories/`, SITE.url).toString();
const categoriesTitle = t('nav.categories');
const categoriesDescription = t('categories.description');
const collectionPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: categoriesTitle,
  description: categoriesDescription,
  url: categoriesUrl,
  inLanguage: SITE.hreflang[lang],
  isPartOf: { '@type': 'WebSite', name: SITE.title, url: SITE.url },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: catTerms.length,
    itemListElement: catTerms.map(([name, count], i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name,
      url: new URL(`/${lang}/categories/${name}/`, SITE.url).toString(),
      description: `${count} ${count === 1 ? 'post' : 'posts'}`,
    })),
  },
};
---

<BaseLayout title={categoriesTitle} description={categoriesDescription} lang={lang}>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(collectionPageJsonLd)}
    slot="head"
  />
  <div style="max-width:1000px; margin:0 auto; padding:64px 32px 96px;">
    <header style="margin-bottom:40px;">
      <div
        style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:14px;"
      >
        {t('categories.breadcrumb')}
      </div>
      <h1
        style="font-family:'Source Serif 4 Variable',serif; font-weight:600; font-size:clamp(36px,4vw,44px); line-height:1.15; color:var(--text); margin:0 0 12px;"
      >
        {t('nav.categories')}
      </h1>
      <p
        style="font-family:'Source Serif 4 Variable',serif; font-size:17px; line-height:1.6; color:var(--text-2); margin:0; max-width:60ch;"
      >
        {t('categories.description')}
      </p>
    </header>

    <div style="display:flex; gap:6px; margin-bottom:32px; border-bottom:1px solid var(--border);">
      <a class="tax-tab" href={`/${lang}/tags/`}
        >Tags <span class="ct">{allPosts.reduce((acc, p) => acc + p.data.tags.length, 0)}</span></a
      >
      <a class="tax-tab active" href={`/${lang}/categories/`}
        >{t('nav.categories')} <span class="ct">{categories.size}</span></a
      >
    </div>

    <div style="display:flex; flex-direction:column;">
      {
        catTerms.map(([name, count], i) => (
          <a
            href={`/${lang}/categories/${name}/`}
            style="display:grid; grid-template-columns:32px minmax(140px,220px) 1fr 56px; align-items:center; gap:20px; padding:16px 0; border-bottom:1px solid var(--border); text-decoration:none; color:inherit; transition:color 150ms ease;"
            onmouseover="this.querySelector('.freq-name').style.color='var(--accent)'"
            onmouseout="this.querySelector('.freq-name').style.color='var(--text)'"
            onfocus="this.querySelector('.freq-name').style.color='var(--accent)'"
            onblur="this.querySelector('.freq-name').style.color='var(--text)'"
          >
            <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-align:right;">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span
              class="freq-name"
              style="font-family:'Geist Variable',sans-serif; font-size:16px; font-weight:500; color:var(--text);"
            >
              {name}
            </span>
            <span style="position:relative; height:6px; background:var(--bar-track); border-radius:3px; overflow:hidden;">
              <span
                style={`height:100%; background:var(--bar); border-radius:3px; display:block; width:${((count / maxCount) * 100).toFixed(1)}%;`}
              />
            </span>
            <span style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--text-2); text-align:right;">
              {count}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .tax-tab {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--text-2);
    padding: 10px 14px 12px;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    transition: all 150ms ease;
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }
  .tax-tab .ct {
    color: var(--text-3);
    font-size: 11px;
  }
  .tax-tab:hover {
    color: var(--text);
  }
  .tax-tab.active {
    color: var(--text);
    border-bottom-color: var(--accent);
  }
</style>
