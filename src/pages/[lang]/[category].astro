---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { getPostUrl, getReadingTime, useTranslations } from '@/i18n/utils';
import { SITE } from '@/config/site';
import { getCategoryLabel, getCategorySlug, CATEGORIES, type Category } from '@/config/taxonomy';
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const catsByLang = new Map<string, Map<string, typeof posts>>();

  posts.forEach((post) => {
    const lang = post.data.lang;
    if (!catsByLang.has(lang)) catsByLang.set(lang, new Map());
    const langCats = catsByLang.get(lang)!;
    const cat = post.data.category;
    if (!langCats.has(cat)) langCats.set(cat, []);
    langCats.get(cat)!.push(post);
  });

  // Only generate paths for valid category slugs — prevents this dynamic route
  // from swallowing unrelated [lang]/[something] requests.
  const validCategories = new Set(CATEGORIES as unknown as string[]);
  const paths: any[] = [];
  catsByLang.forEach((cats, lang) => {
    cats.forEach((posts, canonicalCategory) => {
      if (validCategories.has(canonicalCategory)) {
        const urlSlug = getCategorySlug(canonicalCategory as Category, lang as 'es' | 'en');
        paths.push({ params: { lang, category: urlSlug }, props: { canonicalCategory, posts } });
      }
    });
  });
  return paths;
};

const { canonicalCategory, posts: catPosts } = Astro.props as {
  canonicalCategory: string;
  posts: CollectionEntry<'posts'>[];
};
const lang = Astro.params.lang as 'es' | 'en';
const t = useTranslations(lang);
const sorted = catPosts.sort((a: any, b: any) => b.data.date.getTime() - a.data.date.getTime());
const categoryLabel = getCategoryLabel(canonicalCategory as Category, lang);

const categoryDescription =
  lang === 'es'
    ? `${sorted.length} ${sorted.length === 1 ? 'artículo' : 'artículos'} en la categoría ${categoryLabel}.`
    : `${sorted.length} ${sorted.length === 1 ? 'article' : 'articles'} in the ${categoryLabel} category.`;
const urlSlug = Astro.params.category;
const categoryUrl = new URL(`/${lang}/${urlSlug}/`, SITE.url).toString();

// Hreflang: always explicit to handle asymmetric slugs (e.g. /es/carrera/ ↔ /en/career/)
const esSlug = getCategorySlug(canonicalCategory as Category, 'es');
const enSlug = getCategorySlug(canonicalCategory as Category, 'en');
const categoryAltUrls = { es: `/es/${esSlug}/`, en: `/en/${enSlug}/` };
const collectionPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: categoryLabel,
  description: categoryDescription,
  url: categoryUrl,
  inLanguage: SITE.hreflang[lang],
  isPartOf: { '@type': 'WebSite', name: SITE.title, url: SITE.url },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: sorted.length,
    itemListElement: sorted.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: new URL(getPostUrl(lang, post.data.slug), SITE.url).toString(),
      name: post.data.title,
    })),
  },
};
---

<BaseLayout
  title={categoryLabel}
  description={categoryDescription}
  lang={lang}
  altUrls={categoryAltUrls}
  manualHreflang={true}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(collectionPageJsonLd)}
    slot="head"
  />
  <div style="max-width:720px; margin:0 auto; padding:64px 32px 96px;">
    <header style="margin-bottom:40px;">
      <div
        style="font-family:var(--font-mono); font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:14px;"
      >
        {t('categories.breadcrumb')} / {categoryLabel}
      </div>
      <h1
        style="font-family:var(--font-serif); font-weight:600; font-size:clamp(36px,4vw,44px); line-height:1.15; color:var(--text); margin:0 0 12px;"
      >
        {categoryLabel}
      </h1>
      <p
        style="font-family:var(--font-serif); font-size:17px; line-height:1.6; color:var(--text-2); margin:0;"
      >
        {sorted.length}
        {lang === 'es' ? 'artículos en la categoría' : 'articles in'}
        <em style="color:var(--text);">{categoryLabel}</em>
      </p>
    </header>

    <div style="display:flex; flex-direction:column;">
      {
        sorted.map((post: any) => (
          <PostCard
            title={post.data.title}
            href={getPostUrl(lang, post.data.slug)}
            date={post.data.date.toISOString()}
            tags={post.data.tags}
            description={post.data.description}
            readingTime={getReadingTime(post.body ?? '')}
            variant="row"
          />
        ))
      }
    </div>
  </div>
</BaseLayout>
