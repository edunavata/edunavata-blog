---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations, getPostUrl, getReadingTime } from '@/i18n/utils';
import { SITE } from '@/config/site';

export const getStaticPaths = () => [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];

const { lang } = Astro.params as { lang: 'es' | 'en' };
const t = useTranslations(lang);

const aiPosts = await getCollection(
  'posts',
  ({ data }) => data.lang === lang && !data.draft && data.origins?.includes('ai-generated') === true
);
const sorted = aiPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pageTitle = t('ai.pageTitle');
const pageDescription = t('ai.pageDescription');
const pageUrl = new URL(`/${lang}/ai-generated/`, SITE.url).toString();

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: pageUrl,
  inLanguage: SITE.hreflang[lang],
  isPartOf: {
    '@type': 'WebSite',
    name: SITE.title,
    url: SITE.url,
  },
  hasPart: sorted.slice(0, 20).map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date.toISOString(),
    url: new URL(getPostUrl(lang, post.data.slug), SITE.url).toString(),
  })),
};
---

<BaseLayout title={pageTitle} description={pageDescription} lang={lang} noindex={sorted.length < 5}>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(collectionJsonLd)}
    slot="head"
  />
  <div style="max-width:720px; margin:0 auto; padding:64px 32px 96px;">
    <header style="margin-bottom:48px;">
      <div
        style="font-family:var(--font-mono); font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:14px;"
      >
        / ai-generated
      </div>
      <h1
        style="font-family:var(--font-serif); font-weight:600; font-size:clamp(32px,4vw,44px); line-height:1.15; letter-spacing:-0.015em; color:var(--text); margin:0 0 14px;"
      >
        {pageTitle}
      </h1>
      <p
        style="font-family:var(--font-serif); font-size:17px; line-height:1.6; color:var(--text-2); margin:0; max-width:56ch;"
      >
        {pageDescription}
      </p>
      <div
        style="font-family:var(--font-mono); font-size:13px; color:var(--text-3); margin-top:18px;"
      >
        <span>{sorted.length} {t('blog.articles')}</span>
      </div>
    </header>

    {
      sorted.length > 0 ? (
        <div>
          {sorted.map((post) => (
            <PostCard
              title={post.data.title}
              href={getPostUrl(lang, post.data.slug)}
              date={post.data.date.toISOString()}
              tags={post.data.tags}
              description={post.data.description}
              readingTime={getReadingTime(post.body ?? '')}
              variant="row"
              lang={lang}
              origins={post.data.origins}
              aiModel={post.data.aiModel}
            />
          ))}
        </div>
      ) : (
        <p style="padding:80px 0; text-align:center; color:var(--text-3); font-family:var(--font-mono); font-size:13px;">
          {lang === 'es'
            ? 'Aún no hay artículos generados con IA.'
            : 'No AI-generated articles yet.'}
        </p>
      )
    }
  </div>
</BaseLayout>
