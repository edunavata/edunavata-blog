---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TagPill from '@/components/TagPill.astro';
import AiBadge from '@/components/AiBadge.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations, getPostUrl, getReadingTime, formatDate } from '@/i18n/utils';
import { ui } from '@/i18n/ui';
import { SITE } from '@/config/site';
import { getCategoryLabel, type Category } from '@/config/taxonomy';
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { Image, getImage } from 'astro:assets';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { lang: post.data.lang, slug: post.data.slug },
    props: { post },
  }));
};

const { post } = Astro.props as { post: CollectionEntry<'posts'> };
const { Content, headings } = await render(post);
const lang = post.data.lang as 'es' | 'en';
const t = useTranslations(lang);
const readingTime = getReadingTime(post.body ?? '');

const tocItems = headings
  .filter((h: any) => h.depth >= 2 && h.depth <= 3)
  .map((h: any) => ({ depth: h.depth, text: h.text, slug: h.slug }));

const formattedDate = formatDate(post.data.date, lang);
const updatedDate = post.data.updatedDate ? formatDate(post.data.updatedDate, lang) : null;
const minuteReadFn = ui[lang]['blog.minuteRead'];
const readingTimeLabel =
  typeof minuteReadFn === 'function' ? minuteReadFn(readingTime) : minuteReadFn;

const allPosts = await getCollection('posts', ({ data }) => data.lang === lang && !data.draft);
const related = allPosts
  .filter(
    (p) => p.data.slug !== post.data.slug && p.data.tags.some((tag) => post.data.tags.includes(tag))
  )
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

// Find the post's translation (same folder, different language) for hreflang.
// Posts use `filePath` like "src/content/posts/<folder>/index.<lang>.md" — the
// folder is the implicit translation key.
const folderOf = (p: CollectionEntry<'posts'>): string | null => {
  const fp = (p as any).filePath as string | undefined;
  if (!fp) return null;
  const parts = fp.split('/');
  const i = parts.indexOf('posts');
  return i >= 0 && parts[i + 1] ? parts[i + 1] : null;
};
const currentFolder = folderOf(post);
const allPostsAnyLang = await getCollection('posts', ({ data }) => !data.draft);
const translation = currentFolder
  ? allPostsAnyLang.find(
      (p) => p.id !== post.id && p.data.lang !== lang && folderOf(p) === currentFolder
    )
  : undefined;
const currentUrl = `/${lang}/posts/${post.data.slug}/`;
const altUrls = translation
  ? {
      [lang]: currentUrl,
      [translation.data.lang]: `/${translation.data.lang}/posts/${translation.data.slug}/`,
    }
  : undefined;

const ogImagePath = post.data.cover?.image
  ? (await getImage({ src: post.data.cover.image, format: 'jpg', width: 1200, height: 630 })).src
  : `/og/${lang}-${post.data.slug}.png`;

const ogImageAlt = post.data.cover?.alt ?? post.data.title;

const modifiedDateISO = (post.data.updatedDate ?? post.data.date).toISOString();
const blogPostingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description ?? '',
  datePublished: post.data.date.toISOString(),
  dateModified: modifiedDateISO,
  image: new URL(ogImagePath, SITE.url).toString(),
  url: new URL(`/${lang}/posts/${post.data.slug}/`, SITE.url).toString(),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/${lang}/posts/${post.data.slug}/`, SITE.url).toString(),
  },
  author: {
    '@type': 'Person',
    name: post.data.author,
    url: new URL(`/${lang}/about/`, SITE.url).toString(),
    sameAs: SITE.sameAs,
  },
  publisher: {
    '@type': 'Person',
    name: post.data.author,
    url: new URL(`/${lang}/about/`, SITE.url).toString(),
    sameAs: SITE.sameAs,
  },
  inLanguage: SITE.hreflang[lang],
  keywords: post.data.tags.join(', '),
};

const primaryCategory = post.data.category ?? null;
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: t('nav.home'),
      item: new URL(`/${lang}/`, SITE.url).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t('nav.blog'),
      item: new URL(`/${lang}/blog/`, SITE.url).toString(),
    },
    ...(primaryCategory
      ? [
          {
            '@type': 'ListItem',
            position: 3,
            name: getCategoryLabel(primaryCategory as Category, lang),
            item: new URL(`/${lang}/${primaryCategory}/`, SITE.url).toString(),
          },
        ]
      : []),
    {
      '@type': 'ListItem',
      position: primaryCategory ? 4 : 3,
      name: post.data.title,
      item: new URL(`/${lang}/posts/${post.data.slug}/`, SITE.url).toString(),
    },
  ],
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  lang={lang}
  image={ogImagePath}
  imageAlt={ogImageAlt}
  ogType="article"
  articleDate={post.data.date}
  articleModifiedDate={post.data.updatedDate}
  altUrls={altUrls}
  manualHreflang
  category={post.data.category}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(blogPostingJsonLd)}
    slot="head"
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbJsonLd)}
    slot="head"
  />
  <!-- Progress bar -->
  <div style="position:sticky; top:0; z-index:50; height:2px; background:transparent;">
    <div
      id="progress"
      style="height:2px; background:var(--accent); width:100%; transform:scaleX(0); transform-origin:left; transition:transform 80ms linear;"
    >
    </div>
  </div>

  <div class="post-layout">
    <article class="post-article">
      <!-- Breadcrumb -->
      <nav
        style="font-size:13px; color:var(--text-3); display:flex; align-items:center; gap:8px; margin-bottom:28px; font-family:var(--font-mono);"
        aria-label="breadcrumb"
      >
        <a href={`/${lang}/blog/`} style="color:var(--text-2); text-decoration:none;"
          >{t('nav.blog')}</a
        >
        <span style="opacity:0.4;">/</span>
        <span style="color:var(--text-3);">{post.data.title}</span>
      </nav>

      <!-- Tags -->
      {
        post.data.tags.length > 0 && (
          <div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:18px;">
            {post.data.tags.map((tag: string) => (
              <TagPill tag={tag} href={`/${lang}/tags/${tag}/`} />
            ))}
          </div>
        )
      }

      <!-- Title -->
      <h1
        transition:name={`post-title-${post.data.slug}`}
        style="font-family:var(--font-serif); font-weight:600; font-size:clamp(36px,4vw,48px); line-height:1.15; letter-spacing:-0.015em; margin:0 0 22px; color:var(--text); text-wrap:balance;"
      >
        {post.data.title}
      </h1>

      <!-- Meta bar -->
      <div
        style="display:flex; flex-wrap:wrap; align-items:center; gap:14px; font-size:14px; color:var(--text-3); font-family:var(--font-mono); margin-bottom:40px; padding-bottom:24px; border-bottom:1px solid var(--border);"
      >
        <span>{formattedDate}</span>
        <span
          class="dot"
          style="width:3px; height:3px; border-radius:50%; background:var(--text-3); opacity:0.6;"
        ></span>
        <span>{readingTimeLabel}</span>
        {
          updatedDate && (
            <>
              <span
                class="dot"
                style="width:3px; height:3px; border-radius:50%; background:var(--text-3); opacity:0.6;"
              />
              <span>
                {t('blog.updateAt')} {updatedDate}
              </span>
            </>
          )
        }
        {
          post.data.origins?.includes('ai-generated') && (
            <AiBadge model={post.data.aiModel} lang={lang} />
          )
        }
      </div>

      <!-- Cover -->
      {
        post.data.cover && (
          <div style="width:100%; aspect-ratio:16/9; border-radius:10px; border:1px solid var(--border); margin-bottom:48px; overflow:hidden;">
            <Image
              src={post.data.cover.image}
              alt={post.data.cover.alt || ''}
              loading="eager"
              fetchpriority="high"
              style="width:100%; height:100%; object-fit:cover;"
            />
          </div>
        )
      }

      <!-- Inline ToC (mobile/tablet only — desktop uses sticky sidebar) -->
      {
        tocItems.length > 0 && (
          <details class="toc-inline" open>
            <summary class="toc-inline__summary">
              <span>{t('blog.inThisPage')}</span>
              <svg
                class="toc-inline__chevron"
                aria-hidden="true"
                width="14"
                height="14"
                viewBox="0 0 14 14"
                fill="none"
              >
                <path
                  d="M3 5l4 4 4-4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </summary>
            <ul
              class="toc toc-inline__list"
              style="list-style:none; margin:0; padding:0; border-left:1px solid var(--border);"
            >
              {tocItems.map((item: any) => (
                <li class:list={[item.depth === 3 && 'toc-l2']}>
                  <a href={`#${item.slug}`}>{item.text}</a>
                </li>
              ))}
            </ul>
          </details>
        )
      }

      <!-- Body -->
      <div class="body" id="body">
        <Content />
      </div>

      <!-- Related -->
      {
        related.length > 0 && (
          <section style="margin-top:80px; padding-top:32px; border-top:1px solid var(--border);">
            <div style="font-family:var(--font-mono); font-size:12px; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-3); margin-bottom:20px;">
              {t('blog.relatedPosts')}
            </div>
            <div class="related-grid">
              {related.map((r) => (
                <a
                  href={getPostUrl(lang, r.data.slug)}
                  style="display:block; padding:20px 22px; border:1px solid var(--border); border-radius:10px; background:transparent; text-decoration:none; color:var(--text); transition:border-color 200ms ease, background-color 200ms ease;"
                  onmouseover="this.style.borderColor='var(--border-strong)'; this.style.background='var(--surface)'"
                  onmouseout="this.style.borderColor='var(--border)'; this.style.background='transparent'"
                  onfocus="this.style.borderColor='var(--border-strong)'; this.style.background='var(--surface)'"
                  onblur="this.style.borderColor='var(--border)'; this.style.background='transparent'"
                >
                  <div style="font-family:var(--font-mono); font-size:11px; color:var(--accent); text-transform:uppercase; letter-spacing:0.05em; margin-bottom:10px;">
                    {r.data.tags[0] || ''}
                  </div>
                  <h4 style="font-family:var(--font-serif); font-size:18px; font-weight:600; line-height:1.3; margin:0 0 8px;">
                    {r.data.title}
                  </h4>
                  <p style="font-size:13.5px; color:var(--text-2); margin:0; line-height:1.55;">
                    {r.data.description}
                  </p>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </article>

    <!-- Sidebar -->
    <aside class="post-aside">
      <div class="toc-sidebar-wrapper">
        {
          tocItems.length > 0 && (
            <div style="margin-bottom:36px;">
              <div style="font-family:var(--font-mono); font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-3); margin-bottom:14px;">
                {t('blog.inThisPage')}
              </div>
              <ul
                class="toc"
                id="toc"
                style="list-style:none; margin:0; padding:0; border-left:1px solid var(--border);"
              >
                {tocItems.map((item: any) => (
                  <li class:list={[item.depth === 3 && 'toc-l2']}>
                    <a href={`#${item.slug}`}>{item.text}</a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>

      <div style="margin-bottom:36px;">
        <div
          style="font-family:var(--font-mono); font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-3); margin-bottom:14px;"
        >
          {t('blog.share')}
        </div>
        <div style="display:flex; flex-wrap:wrap; gap:8px;">
          <button class="share-btn" id="copy-link">
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path
                d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg
            >
            <span>{t('blog.shareLink')}</span>
          </button>
          <a
            class="share-btn"
            href={`https://x.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(post.data.title)}`}
            target="_blank"
            rel="noopener"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path></svg
            >
            <span>{t('blog.shareX')}</span>
          </a>
        </div>
      </div>

      {
        post.data.tags.length > 0 && (
          <div>
            <div style="font-family:var(--font-mono); font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-3); margin-bottom:14px;">
              Tags
            </div>
            <div style="display:flex; flex-wrap:wrap; gap:8px;">
              {post.data.tags.map((tag: string) => (
                <TagPill tag={tag} href={`/${lang}/tags/${tag}/`} />
              ))}
            </div>
          </div>
        )
      }
    </aside>
  </div>
</BaseLayout>

<style>
  .toc li a {
    display: block;
    padding: 6px 0 6px 14px;
    margin-left: -1px;
    border-left: 1px solid transparent;
    color: var(--text-2);
    text-decoration: none;
    font-size: 13.5px;
    line-height: 1.45;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }
  .toc li.toc-l2 a {
    padding-left: 26px;
    font-size: 13px;
  }
  .toc li a:hover {
    color: var(--text);
  }
  .toc li.active > a {
    color: var(--text);
    border-left-color: var(--accent);
    font-weight: 500;
  }
  .share-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-2);
    border-radius: 8px;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 13px;
    text-decoration: none;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }
  .share-btn:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }
  .share-btn.ok {
    color: var(--accent);
    border-color: var(--callout-info-bd);
  }

  /* ───────── Inline ToC (mobile/tablet) ───────── */
  .toc-inline {
    margin-bottom: 40px;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .toc-inline {
      display: none;
    }
  }

  .toc-inline__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-3);
    background: var(--surface-2);
    user-select: none;
  }
  .toc-inline__summary::-webkit-details-marker {
    display: none;
  }

  .toc-inline__chevron {
    color: var(--text-3);
    transition: transform 200ms ease;
    flex-shrink: 0;
  }
  details[open] .toc-inline__chevron {
    transform: rotate(180deg);
  }

  .toc-inline__list {
    padding: 8px 0;
    background: var(--surface);
  }

  /* ───────── Sidebar ToC: solo desktop ───────── */
  .toc-sidebar-wrapper {
    display: none;
  }
  @media (min-width: 1024px) {
    .toc-sidebar-wrapper {
      display: block;
    }
  }

  /* ───────── Layout — mobile-first ───────── */
  .post-layout {
    max-width: 100%;
    margin: 0 auto;
    padding: 40px 20px 64px;
  }
  .post-article {
    min-width: 0;
    max-width: 100%;
  }
  .post-aside {
    font-size: 13.5px;
    color: var(--text-2);
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 640px) {
    .post-layout {
      padding: 48px 32px 80px;
    }
    .related-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .post-layout {
      max-width: 1180px;
      padding: 56px 32px 96px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: 72px;
    }
    .post-article {
      max-width: 720px;
    }
    .post-aside {
      position: sticky;
      top: 64px;
      align-self: start;
      max-height: calc(100vh - 80px);
      overflow-y: auto;
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
      scrollbar-width: thin;
      scrollbar-color: transparent transparent;
      transition: scrollbar-color 0.3s ease;
    }
    .post-aside:hover {
      scrollbar-color: var(--border-strong) transparent;
    }
  }
  .post-aside::-webkit-scrollbar {
    width: 3px;
  }
  .post-aside::-webkit-scrollbar-track {
    background: transparent;
  }
  .post-aside::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 3px;
  }
  .post-aside:hover::-webkit-scrollbar-thumb {
    background: var(--border-strong);
  }
  .post-aside::-webkit-scrollbar-thumb:hover {
    background: var(--text-3);
  }
</style>

<script>
  function setupPost() {
    if (window.__postController) window.__postController.abort();

    const progress = document.getElementById('progress');
    if (!progress) return;

    window.__postController = new AbortController();
    const { signal } = window.__postController;

    let activeHash = window.location.hash || '';

    function setActiveTocLink(id: string) {
      document.querySelectorAll('.toc a').forEach((a) => {
        if (a.parentElement)
          a.parentElement.classList.toggle('active', a.getAttribute('href') === '#' + id);
      });
    }

    function updateHash(id: string, mode: string) {
      if (!id) return;
      const nextHash = '#' + id;
      if (activeHash === nextHash) return;
      activeHash = nextHash;
      if (mode === 'push') window.history.pushState(null, '', nextHash);
      else window.history.replaceState(null, '', nextHash);
    }

    function onScroll() {
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docH = document.documentElement.scrollHeight - window.innerHeight;
      const pct = Math.max(0, Math.min(1, scrollTop / Math.max(1, docH)));
      progress!.style.transform = 'scaleX(' + pct.toFixed(4) + ')';

      const offset = 120;
      const ids = [...document.querySelectorAll('.toc a')]
        .map((a) => (a.getAttribute('href') || '').slice(1))
        .filter((id, i, all) => id && all.indexOf(id) === i);
      const headings = ids
        .map((id) => document.getElementById(id))
        .filter((el): el is HTMLElement => el !== null);
      let activeHeading = headings[0];
      headings.forEach((h) => {
        if (h.getBoundingClientRect().top - offset <= 0) activeHeading = h;
      });
      if (activeHeading?.id) {
        setActiveTocLink(activeHeading.id);
        updateHash(activeHeading.id, 'replace');
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true, signal });
    onScroll();

    document.querySelectorAll('.toc a').forEach((a) => {
      a.addEventListener(
        'click',
        (e) => {
          e.preventDefault();
          const id = (a.getAttribute('href') || '').slice(1);
          const target = id && document.getElementById(id);
          if (target) {
            const top = target.getBoundingClientRect().top + window.scrollY - 80;
            setActiveTocLink(id);
            updateHash(id, 'push');
            window.scrollTo({ top, behavior: 'smooth' });
          }
        },
        { signal }
      );
    });

    const copyBtn = document.getElementById('copy-link');
    if (copyBtn) {
      copyBtn.addEventListener(
        'click',
        async () => {
          try {
            await navigator.clipboard.writeText(location.href);
          } catch {
            /* clipboard unsupported */
          }
          copyBtn.classList.add('ok');
          const span = copyBtn.querySelector('span');
          const old = span ? span.textContent : '';
          if (span) span.textContent = '✓ Copiado';
          setTimeout(() => {
            copyBtn.classList.remove('ok');
            if (span) span.textContent = old;
          }, 1600);
        },
        { signal }
      );
    }
  }

  document.addEventListener('astro:page-load', setupPost);
</script>
