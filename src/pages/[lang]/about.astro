---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TagPill from '@/components/TagPill.astro';
import { about } from '@/data/about';
import { timeline } from '@/data/timeline';
import { stack } from '@/data/stack';
import { contact } from '@/data/contact';
import { useTranslations } from '@/i18n/utils';
import { SITE } from '@/config/site';
import { Image } from 'astro:assets';
import avatarImg from '@/assets/avatar.jpg';

export const getStaticPaths = () => [
  { params: { lang: 'es' } },
  { params: { lang: 'en' } },
];

const { lang } = Astro.params as { lang: 'es' | 'en' };
const t = useTranslations(lang);
const data = about[lang];

const contactIcons: Record<string, string> = {
  email: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>`,
  github: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57v-2.07c-3.345.72-4.05-1.605-4.05-1.605-.54-1.395-1.335-1.755-1.335-1.755-1.08-.735.09-.72.09-.72 1.2.09 1.83 1.23 1.83 1.23 1.065 1.83 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.475-1.335-5.475-5.94 0-1.32.465-2.385 1.23-3.225-.12-.3-.54-1.515.12-3.165 0 0 1.005-.33 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.865.12 3.165.765.84 1.23 1.905 1.23 3.225 0 4.62-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22v3.285c0 .315.225.69.825.57C20.565 21.795 24 17.31 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  x: `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  rss: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1.5" fill="currentColor"/></svg>`,
  sourcehut: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
  mastodon: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
};

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author,
  url: SITE.url,
  jobTitle: data.heroRole,
  sameAs: contact
    .filter(c => ['github', 'x', 'mastodon'].includes(c.icon))
    .map(c => c.href),
};
---

<BaseLayout title={t('nav.about')} lang={lang}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personJsonLd)} slot="head" />

  <main style="max-width:920px; margin:0 auto; padding:64px 32px 96px;">

    <!-- HERO -->
    <section style="display:grid; grid-template-columns:140px 1fr; gap:36px; align-items:center; padding-bottom:56px; border-bottom:1px solid var(--border);">
      <div class="avatar" style="width:140px; height:140px; border-radius:50%; border:1px solid var(--border); overflow:hidden;">
        <Image src={avatarImg} alt="Edu González" width={140} height={140} style="width:100%; height:100%; object-fit:cover;" />
      </div>
      <div>
        <div class="eyebrow" style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:10px; display:flex; align-items:center; gap:10px;">
          <span class="status-dot" style="width:7px; height:7px; border-radius:50%; background:oklch(0.74 0.14 145); box-shadow:0 0 0 3px oklch(0.74 0.14 145 / 0.18);"></span>
          <span>{data.heroEyebrow}</span>
        </div>
        <h1 style="font-family:'Source Serif 4 Variable',serif; font-weight:600; font-size:clamp(34px,4vw,44px); line-height:1.1; letter-spacing:-0.02em; margin:0 0 8px; color:var(--text);">
          {data.heroName} <em style="font-style:italic; color:var(--text-2); font-weight:500;">— {data.heroTagline}</em>
        </h1>
        <p style="font-family:'Source Serif 4 Variable',serif; font-size:17px; color:var(--text-2); margin:0;">
          {data.heroRole}
        </p>
      </div>
    </section>

    <!-- INTRO -->
    <section style="padding:56px 0; border-bottom:1px solid var(--border); font-family:'Source Serif 4 Variable',serif; font-size:19px; line-height:1.72; color:var(--text); max-width:64ch;">
      {data.introParagraphs.map(p => <p style="margin:0;">{
        p.split(/(\[.*?\]\(.*?\))/g).map(part => {
          const match = part.match(/\[(.*?)\]\((.*?)\)/);
          if (match) return <a href={match[2]} style="color:var(--accent); text-decoration:underline; text-underline-offset:3px; text-decoration-thickness:1px; text-decoration-color:color-mix(in oklch, var(--accent), transparent 60%);">{match[1]}</a>;
          return part;
        })
      }</p>)}
    </section>

    <!-- TIMELINE / NOW -->
    <section style="padding:56px 0; border-bottom:1px solid var(--border);">
      <div style="font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-3); margin-bottom:28px;">{t('about.now')}</div>
      <div style="display:flex; flex-direction:column; font-family:'Source Serif 4 Variable',serif; font-size:17px; line-height:1.55;">
        {timeline.map(item => (
          <div style="display:grid; grid-template-columns:100px 1fr; gap:28px; padding:18px 0; border-bottom:1px solid var(--border); align-items:baseline;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.06em;">{item.when}</span>
            <div set:html={item.what.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/<(.*?)>/g, '<em>&lt;$1&gt;</em>')} />
          </div>
        ))}
      </div>
    </section>

    <!-- STACK / USES -->
    <section style="padding:56px 0; border-bottom:1px solid var(--border);">
      <div style="font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-3); margin-bottom:28px;">{t('about.setup')}</div>
      <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:0; border:1px solid var(--border); border-radius:10px; overflow:hidden;">
        {stack.map(item => (
          <div style="display:grid; grid-template-columns:140px 1fr; gap:18px; padding:16px 20px; border-bottom:1px solid var(--border); align-items:baseline;">
            <span style="font-family:'JetBrains Mono',monospace; font-size:12px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.06em;">{item.key}</span>
            <span style="font-family:'Geist Variable',sans-serif; font-size:14.5px; color:var(--text);">
              {item.val} {item.detail && <span style="color:var(--text-3); margin-left:6px; font-size:13px;">{item.detail}</span>}
            </span>
          </div>
        ))}
      </div>
    </section>

    <!-- WRITES ABOUT -->
    <section style="padding:56px 0; border-bottom:1px solid var(--border);">
      <div style="font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-3); margin-bottom:28px;">{t('about.writesAbout')}</div>
      <div style="display:flex; flex-wrap:wrap; gap:8px;">
        {data.topics.map(topic => (
          <TagPill tag={topic.name} href={topic.url} />
        ))}
      </div>
    </section>

    <!-- CONTACT -->
    <section style="padding:56px 0;">
      <div style="font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:var(--text-3); margin-bottom:28px;">{t('about.contact')}</div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px;">
        {contact.map(c => (
          <a href={c.href} style="display:flex; align-items:center; gap:14px; padding:18px 20px; border:1px solid var(--border); border-radius:10px; text-decoration:none; color:inherit; transition:all 200ms ease;" onmouseover="this.style.borderColor='var(--border-strong)'; this.style.background='var(--surface)'" onmouseout="this.style.borderColor='var(--border)'; this.style.background='transparent'">
            <span class="ic" style="width:36px; height:36px; display:grid; place-items:center; color:var(--text-2); border:1px solid var(--border); border-radius:8px; flex-shrink:0;" set:html={contactIcons[c.icon] || ''} />
            <span style="display:flex; flex-direction:column; gap:2px; min-width:0;">
              <span style="font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.06em;">{c.label}</span>
              <span style="font-family:'Geist Variable',sans-serif; font-size:14.5px; color:var(--text); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{c.value}</span>
            </span>
          </a>
        ))}
      </div>

      <!-- PGP -->
      <div style="margin-top:24px; padding:16px 18px; border:1px solid var(--border); border-radius:10px; background:var(--surface); font-family:'JetBrains Mono',monospace; font-size:12.5px; color:var(--text-2); display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
        <span class="label" style="color:var(--text-3); text-transform:uppercase; font-size:10.5px; letter-spacing:0.08em;">PGP</span>
        <code id="pgp-key" style="color:var(--text);">{data.pgp}</code>
        <button
          class="copy-btn"
          id="pgp-copy"
          data-copy={t('about.pgpCopy')}
          data-copied={`✓ ${t('about.pgpCopied')}`}
          style="margin-left:auto; background:transparent; border:1px solid var(--border-strong); color:var(--text-2); border-radius:6px; padding:5px 10px; font-family:'JetBrains Mono',monospace; font-size:11px; cursor:pointer; transition:all 150ms ease;"
        >{t('about.pgpCopy')}</button>
      </div>
    </section>

  </main>
</BaseLayout>

<script is:inline>
  (function () {
    var pgpBtn = document.getElementById('pgp-copy');
    if (pgpBtn) {
      pgpBtn.addEventListener('click', async function () {
        var key = (document.getElementById('pgp-key') || {}).textContent || '';
        try { await navigator.clipboard.writeText(key); } catch (e) {}
        var old = pgpBtn.dataset.copy;
        pgpBtn.style.color = 'var(--accent)';
        pgpBtn.style.borderColor = 'var(--callout-info-bd)';
        pgpBtn.textContent = pgpBtn.dataset.copied;
        setTimeout(function () { pgpBtn.style.color = ''; pgpBtn.style.borderColor = ''; pgpBtn.textContent = old; }, 1600);
      });
    }
  })();
</script>

<style>
  @media (max-width: 720px) {
    section[style*="grid-template-columns: 140px 1fr"] { grid-template-columns: 1fr !important; gap: 24px !important; }
    section[style*="grid-template-columns:repeat(3"] { grid-template-columns: 1fr !important; }
    section[style*="grid-template-columns:repeat(2"] { grid-template-columns: 1fr !important; }
    div[style*="grid-template-columns: 100px"] { grid-template-columns: 1fr !important; gap: 6px !important; }
    div[style*="grid-template-columns:140px"] { border-right: none !important; }
  }
</style>
