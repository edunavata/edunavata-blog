---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = `404 — ${SITE.title}`;
const description = 'Page not found / Página no encontrada.';
---

<BaseLayout title={title} description={description} lang="es" noindex>
  <div style="max-width:720px; margin:0 auto; padding:120px 32px; text-align:center;">
    <div
      style="font-family:'JetBrains Mono',monospace; font-size:13px; color:var(--text-3); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:24px;"
    >
      Error 404
    </div>
    <h1
      style="font-family:'Source Serif 4 Variable',Georgia,serif; font-weight:600; font-size:clamp(48px,6vw,72px); line-height:1.1; letter-spacing:-0.02em; margin:0 0 24px; color:var(--text);"
    >
      Página no encontrada
    </h1>
    <p
      style="font-family:'Source Serif 4 Variable',serif; font-size:18px; line-height:1.6; color:var(--text-2); margin:0 0 12px;"
    >
      Esta ruta no existe en el blog. <em>This route doesn't exist on the blog.</em>
    </p>
    <p
      style="font-family:'Source Serif 4 Variable',serif; font-size:17px; line-height:1.6; color:var(--text-3); margin:0 0 48px;"
    >
      Quizá moví el contenido o nunca existió. / Maybe the content moved or never existed.
    </p>

    <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
      <a href="/es/" class="btn primary"> ← Inicio (ES) </a>
      <a href="/en/" class="btn"> ← Home (EN) </a>
      <a href="/es/blog/" class="btn"> Ver el blog </a>
    </div>
  </div>
</BaseLayout>
