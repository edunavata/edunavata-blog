---
import type { ui } from '@/i18n/ui';
import { switchLangPath } from '@/i18n/utils';

interface Props {
  lang: keyof typeof ui;
  currentPath: string;
  urls?: Partial<Record<keyof typeof ui, string>>;
}

const { lang, currentPath, urls = {} } = Astro.props;

function switchLang(path: string, target: string): string {
  return urls[target as keyof typeof ui] ?? switchLangPath(path, target);
}
---

<div class="lang-selector">
  <a href={switchLang(currentPath, 'es')} class:list={[lang === 'es' && 'active']}>ES</a>
  <span style="color: var(--text-3);">|</span>
  <a href={switchLang(currentPath, 'en')} class:list={[lang === 'en' && 'active']}>EN</a>
</div>
