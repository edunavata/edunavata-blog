---
interface Props {
  model?: string;
  lang?: 'es' | 'en';
}

const { model, lang = 'es' } = Astro.props;
const label = lang === 'en' ? 'AI Generated' : 'Generado con IA';
---

<span class="ai-badge">
  <svg
    width="10"
    height="10"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    aria-hidden="true"
  >
    <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"></path>
  </svg>
  {label}{model && <span class="ai-model"> · {model}</span>}
</span>

<style>
  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 3px 8px;
    border-radius: 4px;
    border: 1px solid oklch(0.83 0.09 75);
    background: oklch(0.96 0.05 75);
    color: oklch(0.42 0.1 60);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ai-model {
    color: oklch(0.55 0.08 65);
  }

  :global(:root[data-theme='dark']) .ai-badge {
    border-color: oklch(0.35 0.08 75);
    background: oklch(0.18 0.05 75);
    color: oklch(0.78 0.1 75);
  }

  :global(:root[data-theme='dark']) .ai-model {
    color: oklch(0.62 0.08 70);
  }
</style>
