---
import AiBadge from './AiBadge.astro';
import { useTranslations, formatDate } from '../i18n/utils';
import { ui } from '../i18n/ui';

interface Props {
  title: string;
  href: string;
  date: string;
  tags: string[];
  description?: string;
  readingTime?: number;
  variant?: 'grid' | 'row';
  origins?: string[];
  aiModel?: string;
  lang?: 'es' | 'en';
}

const {
  title,
  href,
  date,
  tags,
  description,
  readingTime,
  variant = 'grid',
  origins,
  aiModel,
  lang = 'es',
} = Astro.props;
const t = useTranslations(lang);
const formattedDate = formatDate(date, lang);
---

{
  variant === 'grid' ? (
    <a class="post-card" href={href}>
      {tags.length > 0 && <div class="pc-tag">{tags[0]}</div>}
      {origins?.includes('ai-generated') && <AiBadge model={aiModel} lang={lang} />}
      <h3>{title}</h3>
      {description && <p>{description}</p>}
      <div class="pc-meta">
        <span>{formattedDate}</span>
        <span class="dot" />
        {readingTime && <span>{readingTime} min</span>}
      </div>
    </a>
  ) : (
    <a class="post-item" href={href} data-tags={tags.join(' ')}>
      <div class="post-tags">
        {tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
        {origins?.includes('ai-generated') && <AiBadge model={aiModel} lang={lang} />}
      </div>
      <h2>{title}</h2>
      {description && <p>{description}</p>}
      <div class="post-meta">
        <span>{formattedDate}</span>
        <span class="dot" />
        {readingTime && <span>{ui[lang]['blog.minuteRead'](readingTime)}</span>}
        <span class="read">
          {t('blog.readMore')}
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    </a>
  )
}
